# ─────────────────────────────────────────────────────────────
# BizFlow Frontend — Environment Configuration
# Copy this file to `.env` and adjust as needed.
# ─────────────────────────────────────────────────────────────

# Production default (false): the app uses the real FastAPI backend.
# Set true only for offline UI work on in-memory mock data (no backend).
VITE_MOCK_MODE=false

# Base URL for the FastAPI backend (used when VITE_MOCK_MODE=false).
# Vite proxies /api -> http://localhost:8000 during dev (see vite.config.ts).
VITE_API_BASE_URL=/api

# ── AI layer (provider-agnostic) ─────────────────────────────
# In production, AI inference runs server-side. These flags let the mock
# AI service mimic the chosen provider so the UI behaves identically.
#   provider: mock | huggingface | ollama
VITE_AI_PROVIDER=mock

# Hugging Face Inference API (free tier) — used by the backend, shown here
# so the Settings > AI page can reflect the active configuration.
VITE_HF_MODEL_INTENT=facebook/bart-large-mnli
VITE_HF_MODEL_SENTIMENT=distilbert-base-uncased-finetuned-sst-2-english
VITE_HF_MODEL_SUMMARY=facebook/bart-large-cnn

# Ollama (local) — used when provider=ollama
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3
