# ─────────────────────────────────────────────────────────────
# BizFlow Backend — environment
# Copy to `.env`. Sensible defaults let it run on SQLite with no setup.
# ─────────────────────────────────────────────────────────────

APP_NAME=BizFlow API
ENV=development
DEBUG=true

# Secret used to sign JWTs — CHANGE in production.
SECRET_KEY=dev-insecure-change-me-please-32chars-min
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────
# Local default: SQLite (no install needed).
DATABASE_URL=sqlite:///./bizflow.db
# Production (Postgres + pgvector):
# DATABASE_URL=postgresql+psycopg://bizflow:bizflow@localhost:5432/bizflow

# The first account is created via sign-up (POST /api/auth/register).
# Set true only to load optional sample data for evaluation/dev.
SEED_ON_STARTUP=false

# ── CORS (frontend dev origins) ──────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── AI provider: mock | huggingface | ollama ─────────────────
AI_PROVIDER=mock
HF_TOKEN=
HF_MODEL_INTENT=facebook/bart-large-mnli
HF_MODEL_SENTIMENT=distilbert-base-uncased-finetuned-sst-2-english
HF_MODEL_SUMMARY=facebook/bart-large-cnn
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Notifications / integrations ─────────────────────────────
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=BizFlow <no-reply@bizflow.local>

# ── Background jobs (Celery + Redis) ─────────────────────────
REDIS_URL=redis://localhost:6379/0
